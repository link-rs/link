# Docker image for building libquicr for ESP32-S3 using ESP-IDF
#
# Based on the approach from https://github.com/Quicr/hactar/tree/main/firmware/net
#
# Usage:
#   docker build -t quicr-esp32s3-builder -f docker/Dockerfile.esp32s3 .
#   docker run -v $(pwd)/vendor/prebuilt:/output quicr-esp32s3-builder

FROM espressif/idf:v5.4
LABEL description="Build environment for libquicr on ESP32-S3"

# Install additional build tools
RUN apt-get update && apt-get install -y \
    make \
    git \
    curl \
    unzip \
    cmake \
    ninja-build \
    bash \
    pkg-config \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Set up working directory
WORKDIR /build

# Copy the libquicr source and build configuration
COPY libquicr /build/libquicr
COPY docker/esp-idf-component /build/component

# Build script that creates the static libraries
COPY docker/build-libs.sh /build/build-libs.sh
RUN chmod +x /build/build-libs.sh

# Output directory for built libraries
VOLUME /output

# Default command builds libraries and copies to output
CMD ["/build/build-libs.sh"]
